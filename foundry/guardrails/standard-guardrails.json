{
  "name": "Base-Guardrail-v2",
  "inputPolicies": [
    "block-secrets-in-chat",
    "block-credential-exfiltration",
    "block-production-change-without-approval"
  ],
  "outputPolicies": [
    "require-grounding-for-environment-claims",
    "require-escalation-when-confidence-low"
  ],
  "raiPolicyName": "Base-Guardrail-v2",
  "contentFilters": [
    {
      "name": "Indirect Attack",
      "blocking": true,
      "enabled": true,
      "source": "Prompt",
      "action": "NONE"
    },
    {
      "name": "purview",
      "blocking": true,
      "enabled": true,
      "source": "Prompt",
      "action": "NONE"
    },
    {
      "name": "purview",
      "blocking": true,
      "enabled": true,
      "source": "Completion",
      "action": "NONE"
    }
  ],
  "mode": "Default",
  "basePolicyName": "Microsoft.DefaultV2"
}
